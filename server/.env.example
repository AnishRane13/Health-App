# ─── Database (Neon) ───────────────────────────────────────────────────────
# Use the Neon connection string. Pooler host is fine for the running API.
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────────────────────────────
# Render sets PORT automatically in production — do not hardcode there.
PORT=5000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (your Vercel URL, etc.)
CLIENT_URL="http://localhost:5173"

# ─── Optional: AI health insights ────────────────────────────────────────────
# If unset, the insight feature falls back to a rule-based summary.
ANTHROPIC_API_KEY=""
